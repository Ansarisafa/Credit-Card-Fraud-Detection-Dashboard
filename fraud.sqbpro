x="28" value="171"/><column index="29" value="171"/><column index="30" value="62"/><column index="31" value="47"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1">SELECT * 
FROM creditcard 
LIMIT 5;
SELECT COUNT(*) AS total_rows 
FROM creditcard;
SELECT field31 AS class, COUNT(*) AS total
FROM c_final
GROUP BY field31;
</sql><sql name="SQL 2">SELECT COUNT(*) 
FROM creditcard
WHERE field30 IS NULL OR field31 IS NULL;
SELECT MIN(field30), MAX(field30)
FROM creditcard;
SELECT field30 
FROM creditcard
ORDER BY field30 DESC
LIMIT 10;</sql><sql name="SQL 4">PRAGMA table_info(creditcard);
SELECT field31, COUNT(*) 
FROM creditcard 
GROUP BY field31;    
CREATE TABLE clean_new AS
SELECT DISTINCT *
FROM creditcard;
SELECT COUNT(*) FROM creditcard;
SELECT COUNT(*) FROM clean_new;</sql><sql name="SQL 8">CREATE TABLE creditcard_final AS
SELECT *
FROM clean_new
WHERE field31 IN ('0','1');</sql><sql name="SQL 3">SELECT field31,
AVG(field30) AS avg_amount,
MIN(field30) AS min_amount,
MAX(field30) AS max_amount
FROM creditcard_final
GROUP BY field31;
</sql><sql name="SQL 7">SELECT *
FROM creditcard_final
WHERE field31 = 1
ORDER BY CAST(field30 AS REAL) DESC
LIMIT 10;</sql><sql name="SQL 9">SELECT field31,
AVG(CAST(field30 AS REAL)) AS avg_amount,
MIN(CAST(field30 AS REAL)) AS min_amount,
MAX(CAST(field30 AS REAL)) AS max_amount
FROM creditcard_final
GROUP BY field31;</sql><current_tab id="6"/></tab_sql></sqlb_project>
